// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// BETTER AUTH CORE MODELS
// ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  members       Member[]
  invitations   Invitation[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ------------------------------------------------------
// MULTI-TENANCY & RBAC MODELS
// ------------------------------------------------------

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  metadata    String?      // Can store JSON config
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members     Member[]
  invitations Invitation[]
  roles       OrganizationRole[]       
  channels    Channel[]    // Channels belong to the organization

  @@map("organization")
}

model OrganizationRole {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       // e.g., "admin", "moderator"
  permission     String       // Actually stores the permissions string/JSON generated by Better Auth
  
  // Custom Additional Fields (configured in Better Auth)
  color          String?      // Hex code formatting
  isBaseRole     Boolean      @default(false)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, role]) 
  @@map("organizationRole")
}

model Member {
  id             String       @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role           String       // Better Auth expects this to be a string
  
  // Additional Fields
  isBanned       Boolean      @default(false) // Moderation
  
  messages       Message[]    // Messages sent by this member
  threads        Thread[]     // Threads created by this member
  reactions      Reaction[]   // Reactions added by this member
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId]) 
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  email          String
  role           String?      // Desired role for the invited user
  status         String       @default("pending") // pending, accepted, revoked
  
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ------------------------------------------------------
// CHAT, MEDIA & FORUM MODELS
// ------------------------------------------------------

enum ChannelType {
  TEXT
  VOICE // Future-proofing
  FORUM // Only contains threads
}

model Channel {
  id             String       @id @default(cuid())
  name           String
  description    String?
  type           ChannelType  @default(TEXT)
  isPrivate      Boolean      @default(false) // Role-gated channels
  
  // Channel-level Access Control
  allowedRoles   String[]     @default([])    // Array of role names that can read/write if private
  readOnlyRoles  String[]     @default([])    // Array of role names that can ONLY read (applies to public or private channels)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  messages       Message[]
  threads        Thread[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("channel")
}

model Thread {
  id             String       @id @default(cuid())
  name           String
  isArchived     Boolean      @default(false)
  
  channelId      String
  channel        Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  authorId       String
  author         Member       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  parentMessageId String?     @unique // If thread spawned from a message 
  parentMessage   Message?    @relation("MessageToThread", fields: [parentMessageId], references: [id], onDelete: Cascade)
  
  messages       Message[]    @relation("ThreadMessages")
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([channelId])
  @@map("thread")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  isDeleted      Boolean      @default(false)
  editedAt       DateTime?
  
  authorId       String
  author         Member       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  channelId      String?      // Null if sent in a Thread directly
  channel        Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  threadId       String?      // Set if this message belongs to a Thread
  thread         Thread?      @relation("ThreadMessages", fields: [threadId], references: [id], onDelete: Cascade)
  
  attachments    Attachment[]
  reactions      Reaction[]
  
  spawnedThread  Thread?      @relation("MessageToThread")
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([channelId])
  @@index([threadId])
  @@map("message")
}

model Attachment {
  id             String       @id @default(cuid())
  url            String
  fileType       String       // e.g., "image/png", "application/pdf"
  fileName       String
  fileSize       Int          // size in bytes
  
  messageId      String
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
  
  @@index([messageId])
  @@map("attachment")
}

model Reaction {
  id             String       @id @default(cuid())
  emoji          String       // The emoji unicode or shortcode
  
  messageId      String
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  memberId       String
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())

  @@unique([messageId, memberId, emoji]) // Stop user from reacting with same emoji twice
  @@map("reaction")
}
